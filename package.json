{
  "name": "horace-personal-website",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal personal research portfolio website built with Astro.",
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "notes:sync": "node tools/sync-obsidian-notes.mjs",
    "notes:sync:dry": "node tools/sync-obsidian-notes.mjs --dry-run",
    "notes:sync:strict": "node tools/sync-obsidian-notes.mjs --strict"
  },
  "dependencies": {},
  "devDependencies": {
    "astro": "^7.0.3",
    "cross-env": "^10.1.0"
  }
}
