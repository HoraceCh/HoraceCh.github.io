---
interface Props {
  href: string;
  label: string;
  external?: boolean;
  variant?: 'primary' | 'secondary' | 'text';
}

const { href, label, external = false, variant = 'secondary' } = Astro.props;
---

<a
  class={`link-button link-button--${variant}`}
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  {label}
</a>
