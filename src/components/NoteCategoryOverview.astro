---
import SectionHeading from './SectionHeading.astro';

interface Category {
  name: string;
  description: string;
  count: number;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const anchorFor = (name: string) => `category-${name.toLowerCase().replaceAll(' ', '-').replaceAll('&', 'and')}`;
---

<section class="section" aria-labelledby="note-categories-title">
  <SectionHeading
    id="note-categories-title"
    eyebrow="Categories"
    title="Note Categories"
    description="Categories describe the role each note plays in the larger knowledge system."
  />
  <div class="category-grid">
    {
      categories.map((category) => (
        <article class="category-item" id={anchorFor(category.name)}>
          <h3>{category.name}</h3>
          <p>{category.description}</p>
          <p class="meta">{category.count} public note{category.count === 1 ? '' : 's'}</p>
          <a href="#all-notes">View related notes</a>
        </article>
      ))
    }
  </div>
</section>
