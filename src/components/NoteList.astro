---
import NoteCard from './NoteCard.astro';
import { noteHref, type EffectiveNote } from '../utils/notePublication';

interface Props {
  notes: EffectiveNote[];
  emptyMessage?: string;
}

const { notes, emptyMessage = 'No public notes here yet.' } = Astro.props;
---

{
  notes.length > 0 ? (
    <div class="card-grid all-notes-grid" aria-label="Notes">
      {notes.map((note) => (
        <NoteCard
          title={note.data.title}
          description={note.data.publicSummary}
          date={note.data.date}
          category={note.data.category}
          status={note.data.status}
          type={note.data.type}
          tags={note.data.tags}
          href={noteHref(note)}
        />
      ))}
    </div>
  ) : (
    <p class="empty-state">{emptyMessage}</p>
  )
}
