---
import type { NoteModuleNode } from '../utils/noteModules';
import { flattenNoteModuleTree, noteHref } from '../utils/noteModules';

interface Props {
  nodes: NoteModuleNode[];
  emptyMessage?: string;
}

const { nodes, emptyMessage = 'No hierarchy-backed note modules yet.' } = Astro.props;
const formatDate = (date: Date | undefined) =>
  date
    ? new Intl.DateTimeFormat('en', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(date)
    : undefined;
---

{
  nodes.length > 0 ? (
    <div class="module-tree" aria-label="Note collections and modules">
      {nodes.map((node) => {
        const childModules = flattenNoteModuleTree(node.childModules);
        const latestDate = formatDate(node.latestDate);

        return (
          <article class="module-card">
            <div class="module-card__header">
              <p class="eyebrow">{node.segments.length === 1 ? 'Collection' : 'Module'}</p>
              <h3><a href={node.href}>{node.title}</a></h3>
              {node.indexNote?.data.description && <p>{node.indexNote.data.description}</p>}
            </div>

            <dl class="module-card__stats" aria-label={`${node.title} summary`}>
              <div>
                <dt>Notes</dt>
                <dd>{node.ordinaryNoteCount}</dd>
              </div>
              <div>
                <dt>Modules</dt>
                <dd>{node.childModules.length}</dd>
              </div>
              <div>
                <dt>Updated</dt>
                <dd>{latestDate ?? 'TBD'}</dd>
              </div>
            </dl>

            <div class="module-card__actions">
              <a href={node.href}>{node.segments.length === 1 ? 'Browse collection' : 'Browse module'}</a>
              {node.indexNote && <a href={noteHref(node.indexNote.id)}>Index note</a>}
            </div>

            {childModules.length > 0 && (
              <ul class="module-card__children" aria-label={`${node.title} child modules`}>
                {childModules.map((child) => {
                  const depth = Math.min(child.segments.length - node.segments.length - 1, 3);
                  return (
                    <li class={`module-card__child module-card__child--depth-${depth}`}>
                      <a href={child.href}>
                        <span>{child.title}</span>
                        <small>
                          {child.ordinaryNoteCount} note{child.ordinaryNoteCount === 1 ? '' : 's'}
                        </small>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </article>
        );
      })}
    </div>
  ) : (
    <p class="empty-state">{emptyMessage}</p>
  )
}
