---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<div class="section-heading">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 id={id}>{title}</h2>
  {description && <p>{description}</p>}
</div>
