---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = 'Horace Chan';
const {
  title = siteTitle,
  description = 'Personal research portfolio and notes system for robotics, embodied AI, and AI-assisted engineering workflows.',
} = Astro.props;
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main class="site-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
