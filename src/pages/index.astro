---
import Layout from '../layouts/Layout.astro';
import LinkButton from '../components/LinkButton.astro';
import {
  loadProjectPublicationModel,
  projectHref,
  selectHomepageProjects,
} from '../utils/projectPublication';
import { loadNotePublicationModel, noteHref, selectHomepageNotes } from '../utils/notePublication';

const curatedProjectCards = [
  {
    projectId: 'ai-retrieval-tool',
    status: 'In progress',
    type: 'AI Workflow',
    title: 'Academic Retrieval Query Builder',
    description:
      'AI_RETRIEVAL_X / Information-Retrieval-Tool drafts database-specific Boolean queries from a research question.',
  },
  {
    projectId: 'vla-embodied-ai-learning-system',
    status: 'Learning system',
    type: 'Embodied AI',
    title: 'VLA / Embodied AI Learning System',
    description:
      'A structured study system for connecting VLA papers, robotics concepts, and future implementation work.',
  },
];
const curatedProjectIds = curatedProjectCards.map((project) => project.projectId);
const projectModel = await loadProjectPublicationModel();
const missingCuratedProjectIds = curatedProjectIds.filter((id) => !projectModel.byId.has(id));

if (missingCuratedProjectIds.length > 0) {
  throw new Error(`Homepage Project IDs do not resolve: ${missingCuratedProjectIds.join(', ')}`);
}

const selectedProjectCards = selectHomepageProjects(projectModel, curatedProjectIds).map((project) => {
  const card = curatedProjectCards.find((item) => item.projectId === project.id);
  if (!card) {
    throw new Error(`Homepage Project metadata is missing for resolved ID: ${project.id}`);
  }
  return { ...card, href: projectHref(project) };
});
const noteModel = await loadNotePublicationModel();
const selectedWorkNote = selectHomepageNotes(noteModel).find((note) => note.data.homepageSlot === 'selected-work-03');

if (!selectedWorkNote) {
  console.warn('Homepage Note slot selected-work-03 did not resolve to a homepage-eligible Note.');
}

const selectedWork = [
  ...selectedProjectCards,
  ...(selectedWorkNote
    ? [{
        status: selectedWorkNote.data.status,
        type: selectedWorkNote.data.type,
        title: selectedWorkNote.data.title,
        description: selectedWorkNote.data.publicSummary,
        href: noteHref(selectedWorkNote),
      }]
    : []),
];

const hubLinks = [
  {
    href: '/projects/',
    label: 'Projects',
    description: 'Scan active engineering work, research systems, and public tools.',
  },
  {
    href: '/notes/',
    label: 'Notes',
    description: 'Read structured study notes, learning paths, and workflow records.',
  },
];

const focusAreas = [
  'Robotics',
  'Embodied AI',
  'Vision-Language-Action models',
  'Mechanical design',
  'Control systems',
  'AI-assisted workflows',
];
---

<Layout
  title="Horace Chan"
  description="Mechanical Engineering student building and documenting robotics, Embodied AI, and AI-assisted research workflows."
>
  <div class="home-page">
    <section class="home-entry" aria-labelledby="home-title">
      <div class="home-intro">
        <p class="home-kicker">Personal research portfolio</p>
        <div class="name-lockup">
          <div class="name-copy">
            <h1 id="home-title">
              <span>Horace</span>
              <span>Chan</span>
            </h1>
          </div>
          <div class="name-portrait">
            <span class="portrait-monogram" aria-hidden="true">HC</span>
            <img
              class="portrait-mark"
              src="/assets/profile-mark.png"
              alt="Portrait of Horace Chan"
              width="1252"
              height="1252"
              loading="eager"
            />
          </div>
        </div>
        <p class="home-thesis">
          Mechanical Engineering student building and documenting robotics, Embodied AI, and AI-assisted research
          workflows.
        </p>
        <p class="home-summary">
          I connect mechanical systems and robot control with practical study systems for VLA-based embodied
          intelligence.
        </p>
        <nav class="link-row home-primary-links" aria-label="Primary homepage links">
          <LinkButton href="/projects/" label="View Projects" variant="primary" />
          <LinkButton href="/notes/" label="Read Notes" variant="secondary" />
          <LinkButton href="/resume/" label="Resume" variant="text" />
          <LinkButton href="https://github.com/HoraceCh" label="GitHub" variant="text" external />
        </nav>
        <ul class="focus-strip" aria-label="Current focus areas">
          {focusAreas.map((area) => <li>{area}</li>)}
        </ul>
      </div>

      <aside class="identity-plate" aria-label="Profile snapshot">
        <p class="plate-label">Profile snapshot</p>
        <dl>
          <div>
            <dt>Base</dt>
            <dd>Mechanical Engineering</dd>
          </div>
          <div>
            <dt>Focus</dt>
            <dd>Robotics + Embodied AI</dd>
          </div>
          <div>
            <dt>Current Work</dt>
            <dd>AI-assisted research workflows</dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="home-section home-selected-work" aria-labelledby="home-selected-work">
      <div class="home-section-head">
        <p class="eyebrow">Selected work</p>
        <h2 id="home-selected-work">Current projects and learning systems</h2>
      </div>
      <div class="work-grid">
        {selectedWork.map((item) => (
          <a class="work-card" href={item.href}>
            <div class="work-card-meta">
              <span>{item.status}</span>
              <span>{item.type}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="card-action">View project <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section home-approach" aria-labelledby="home-approach">
      <div class="home-section-head">
        <p class="eyebrow">Approach</p>
        <h2 id="home-approach">How I approach the work</h2>
      </div>
      <div class="approach-grid">
        <article>
          <p class="proof-mark">ME</p>
          <h3>Engineering foundation</h3>
          <p>Mechanical systems, design practice, and control fundamentals provide the base for technical decisions.</p>
        </article>
        <article>
          <p class="proof-mark">VLA</p>
          <h3>Embodied AI research</h3>
          <p>Structured reading connects models, robot-learning concepts, and questions for future implementation.</p>
        </article>
        <article>
          <p class="proof-mark">LOG</p>
          <h3>Public documentation</h3>
          <p>Notes and workflow records preserve limitations, revisions, and the reasoning behind each direction.</p>
        </article>
      </div>
    </section>

    <section class="home-section home-hub" aria-labelledby="home-explore">
      <div class="home-section-head">
        <p class="eyebrow">Explore</p>
        <h2 id="home-explore">Continue through the portfolio</h2>
      </div>
      <div class="hub-grid">
        {hubLinks.map((link) => (
          <a class="hub-link" href={link.href}>
            <span>{link.label}</span>
            <small>{link.description}</small>
            <span class="card-action" aria-hidden="true">Explore →</span>
          </a>
        ))}
      </div>
      <nav class="hub-secondary-links" aria-label="Additional homepage links">
        <a href="/resume/">Resume</a>
        <a href="https://github.com/HoraceCh" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="/contact/">Contact</a>
      </nav>
    </section>
  </div>
</Layout>
