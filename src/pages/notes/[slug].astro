---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import NoteProperties from '../../components/notes/NoteProperties.astro';
import NoteSidepane from '../../components/notes/NoteSidepane.astro';
import { buildNoteBacklinksIndex } from '../../utils/noteBacklinks';
import { slugify } from '../../utils/slugify';

const toSlug = (id: string) => id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
const noteHref = (id: string) => `/notes/${toSlug(id)}/`;

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id.replace(/\.mdx?$/, '').replace(/\/index$/, '') },
    props: { note },
  }));
}

const { note } = Astro.props;
const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const notesBySlug = new Map(allNotes.map((entry) => [toSlug(entry.id), entry]));
const backlinksIndex = buildNoteBacklinksIndex(allNotes);
const currentSlug = toSlug(note.id);
const incomingBacklinks = backlinksIndex.backlinksBySlug[currentSlug] ?? [];
const { Content, headings } = await render(note);
const outlineItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const relatedNotes = note.data.related.map((slug: string) => ({
  slug,
  note: notesBySlug.get(slug),
}));
const prerequisiteItems = note.data.prerequisites.map((item: string) => ({
  label: item,
  note: notesBySlug.get(item),
}));
const propertyItems = [
  {
    label: 'Category',
    value: note.data.category,
    href: `/notes/categories/${slugify(note.data.category)}/`,
  },
  {
    label: 'Subcategory',
    value: note.data.subcategory,
  },
  {
    label: 'Learning path',
    value: note.data.path
      ? `${note.data.path}${note.data.order ? ` / step ${note.data.order}` : ''}`
      : undefined,
    href: note.data.path ? `/notes/paths/${slugify(note.data.path)}/` : undefined,
  },
  {
    label: 'Level',
    value: note.data.level,
  },
  {
    label: 'Type',
    value: note.data.type,
    href: `/notes/types/${slugify(note.data.type)}/`,
  },
  {
    label: 'Updated',
    value: note.data.updated
      ? new Intl.DateTimeFormat('en', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        }).format(note.data.updated)
      : undefined,
  },
];
const prerequisiteLinks = prerequisiteItems.map((item) => ({
  label: item.note ? item.note.data.title : item.label,
  href: item.note ? noteHref(item.note.id) : undefined,
}));
const relatedLinks = relatedNotes.map((item) => ({
  label: item.note ? item.note.data.title : item.slug,
  href: item.note ? noteHref(item.note.id) : undefined,
}));
---

<Layout title={note.data.title} description={note.data.description}>
  <article class="article note-article">
    <div class="note-header">
      <p class="back-link"><a href="/notes/">Back to Notes</a></p>
      <h1>{note.data.title}</h1>
      <p class="lead">{note.data.description}</p>
    </div>

    <div class="note-reading-layout">
      <div class="note-properties-slot">
        <NoteProperties
          properties={propertyItems}
          concepts={note.data.concepts}
          prerequisites={prerequisiteLinks}
          relatedNotes={relatedLinks}
          tags={note.data.tags}
          status={note.data.status}
        />
      </div>

      <NoteSidepane outline={outlineItems} backlinks={incomingBacklinks} />

      <div class="note-prose" data-note-prose>
        <Content />
      </div>
    </div>
  </article>

  <script>
    const genericCodeLanguages = new Set(['plaintext', 'text', 'txt', 'plain', 'none']);
    const copyFeedbackDelay = 1600;
    const copyResetTimers = new WeakMap();

    function getReliableCodeLanguage(pre) {
      const language = pre.getAttribute('data-language')?.trim();

      if (!language || genericCodeLanguages.has(language.toLowerCase())) {
        return '';
      }

      if (!/^[a-z0-9#+._-]+$/i.test(language)) {
        return '';
      }

      return language;
    }

    function resetCopyButton(button) {
      button.textContent = 'Copy';
      button.setAttribute('aria-label', 'Copy code');
    }

    function showCopyFeedback(button, label, accessibleLabel) {
      const existingTimer = copyResetTimers.get(button);

      if (existingTimer) {
        window.clearTimeout(existingTimer);
      }

      button.textContent = label;
      button.setAttribute('aria-label', accessibleLabel);

      const resetTimer = window.setTimeout(() => {
        resetCopyButton(button);
        copyResetTimers.delete(button);
      }, copyFeedbackDelay);

      copyResetTimers.set(button, resetTimer);
    }

    function enhanceNoteCodeBlocks() {
      document.querySelectorAll('[data-note-prose] pre').forEach((pre) => {
        if (!(pre instanceof HTMLPreElement) || pre.dataset.noteCodeEnhanced === 'true') {
          return;
        }

        const code = pre.querySelector(':scope > code');

        if (!code) {
          return;
        }

        pre.removeAttribute('tabindex');
        pre.dataset.noteCodeEnhanced = 'true';

        const wrapper = document.createElement('div');
        wrapper.className = 'note-code-block';
        wrapper.dataset.noteCodeBlock = '';

        const header = document.createElement('div');
        header.className = 'note-code-block__header';

        const language = getReliableCodeLanguage(pre);

        if (language) {
          const label = document.createElement('span');
          label.className = 'note-code-block__language';
          label.textContent = language;
          header.append(label);
        } else {
          header.classList.add('note-code-block__header--copy-only');
        }

        const copyButton = document.createElement('button');
        copyButton.className = 'note-code-copy';
        copyButton.type = 'button';
        copyButton.textContent = 'Copy';
        copyButton.setAttribute('aria-label', 'Copy code');
        copyButton.setAttribute('aria-live', 'polite');

        copyButton.addEventListener('click', async () => {
          if (!navigator.clipboard?.writeText) {
            showCopyFeedback(copyButton, 'Unavailable', 'Copy unavailable');
            return;
          }

          try {
            await navigator.clipboard.writeText(code.textContent ?? '');
            showCopyFeedback(copyButton, 'Copied', 'Code copied');
          } catch {
            showCopyFeedback(copyButton, 'Failed', 'Copy failed');
          }
        });

        header.append(copyButton);
        pre.before(wrapper);
        wrapper.append(header, pre);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', enhanceNoteCodeBlocks, { once: true });
    } else {
      enhanceNoteCodeBlocks();
    }

    document.addEventListener('astro:page-load', enhanceNoteCodeBlocks);
  </script>
</Layout>
