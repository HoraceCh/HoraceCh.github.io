---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BrowsePills from '../../components/BrowsePills.astro';
import NoteList from '../../components/NoteList.astro';
import NoteModuleTree from '../../components/NoteModuleTree.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { categoryDefinitions, pathDefinitions, statusDescriptions, typeLabels } from '../../utils/notes';
import {
  buildNoteModuleTree,
  flattenNoteModuleTree,
  isNoteIndexEntry,
  isOrdinaryNote,
  isPublicBrowseNote,
  noteHref,
  sortNotesForHierarchy,
} from '../../utils/noteModules';
import { slugify } from '../../utils/slugify';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const publicBrowseNotes = notes.filter(isPublicBrowseNote);
const noteModules = buildNoteModuleTree(publicBrowseNotes);
const moduleNodes = flattenNoteModuleTree(noteModules);
const ordinaryNotes = publicBrowseNotes.filter(isOrdinaryNote);
const hierarchyIndexNotes = sortNotesForHierarchy(publicBrowseNotes.filter(isNoteIndexEntry));

const categories = categoryDefinitions.map((category) => ({
  ...category,
  count: publicBrowseNotes.filter((note) => note.data.category === category.name).length,
}));

const tagCounts = [...new Set(publicBrowseNotes.flatMap((note) => note.data.tags))]
  .sort((a, b) => a.localeCompare(b))
  .map((tag) => ({
    label: tag,
    href: `/notes/tags/${slugify(tag)}/`,
    count: publicBrowseNotes.filter((note) => note.data.tags.includes(tag)).length,
  }));

const pathCounts = pathDefinitions.map((path) => ({
  label: path.title,
  href: `/notes/paths/${slugify(path.title)}/`,
  count: publicBrowseNotes.filter((note) => note.data.path === path.title).length,
  description: path.purpose,
}));

const typeCounts = Object.entries(typeLabels).map(([type, label]) => ({
  label,
  href: `/notes/types/${slugify(type)}/`,
  count: publicBrowseNotes.filter((note) => note.data.type === type).length,
}));

const statusCounts = Object.entries(statusDescriptions).map(([status, description]) => ({
  label: status,
  href: `/notes/status/${slugify(status)}/`,
  count: publicBrowseNotes.filter((note) => note.data.status === status).length,
  description,
}));

const collectionCounts = noteModules.map((collection) => ({
  label: collection.title,
  href: collection.href,
  count: collection.ordinaryNoteCount,
  description: collection.indexNote?.data.description,
}));

const moduleCounts = moduleNodes
  .filter((module) => module.segments.length > 1)
  .map((module) => ({
    label: module.title,
    href: module.href,
    count: module.ordinaryNoteCount,
    description: module.indexNote?.data.description,
  }));

const recentNotes = ordinaryNotes.slice(0, 5);
const allNotes = [...ordinaryNotes].sort((a, b) => {
  const categoryCompare = a.data.category.localeCompare(b.data.category);
  if (categoryCompare !== 0) return categoryCompare;
  const orderCompare = (a.data.order ?? 999) - (b.data.order ?? 999);
  if (orderCompare !== 0) return orderCompare;
  return a.data.title.localeCompare(b.data.title);
});
---

<Layout title="Notes" description="Public learning notes organized by collections, modules, topics, and recent updates.">
  <section class="notes-hero">
    <p class="eyebrow">Notes</p>
    <h1>Learning Notes</h1>
    <p class="lead">
      Public notes from my learning and project work, organized as a knowledge map instead of a date-only blog archive.
    </p>
    <p>
      Current areas include programming fundamentals, CS fundamentals, robotics, Embodied AI, VLA models,
      mechanical design, control systems, and AI-assisted workflows. Some entries are working notes and may be incomplete.
    </p>
  </section>

  <section class="section notes-module-overview" id="collections">
    <SectionHeading
      eyebrow="Structure"
      title="Collections and Modules"
      description="Start here for structured browsing. Collections and modules group notes by subject, sequence, and project context."
    />
    <NoteModuleTree nodes={noteModules} emptyMessage="No public collections or modules are available yet." />
    <p class="module-overview-link"><a href="/notes/collections/">Browse all collections</a></p>
  </section>

  <section class="section recent-notes">
    <SectionHeading
      eyebrow="Updates"
      title="Recent Notes"
      description="Recently updated individual notes. This is an update feed, not the main structure of the notes system."
    />
    {
      recentNotes.length > 0 ? (
        <div class="compact-note-list" aria-label="Recently updated individual notes">
          {recentNotes.map((note) => (
            <a class="compact-note" href={noteHref(note.id)}>
              <span>{note.data.title}</span>
              <small>{note.data.category} / {note.data.status}</small>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">No recent individual notes yet.</p>
      )
    }
  </section>

  <section class="section browse-section">
    <SectionHeading
      eyebrow="Filters"
      title="Explore by Topic"
      description="Secondary taxonomy views for narrowing the same public notes by collection, module, category, path, tag, type, or status."
    />
    <div class="browse-grid">
      <BrowsePills label="Collections" items={collectionCounts} />
      <BrowsePills label="Modules" items={moduleCounts} />
      <BrowsePills
        label="Categories"
        items={categories.map((category) => ({
          label: category.name,
          href: `/notes/categories/${slugify(category.name)}/`,
          count: category.count,
          description: category.description,
        }))}
      />
      <BrowsePills label="Learning paths" items={pathCounts} />
      <BrowsePills label="Tags" items={tagCounts} />
      <BrowsePills label="Note types" items={typeCounts} />
      <BrowsePills label="Statuses" items={statusCounts} />
    </div>
  </section>

  <section class="section" id="all-notes">
    <SectionHeading
      eyebrow="Archive"
      title="Individual Notes Archive"
      description="Archive-style list of public individual notes. Collection and module index notes and hidden archive branches stay separate."
    />
    <NoteList notes={allNotes} emptyMessage="No public individual notes yet." />

    {
      hierarchyIndexNotes.length > 0 && (
        <div class="module-index-list" aria-labelledby="module-index-list-title">
          <h3 id="module-index-list-title">Collection and Module Index Notes</h3>
          <div class="compact-note-list">
            {hierarchyIndexNotes.map((note) => (
              <a class="compact-note compact-note-muted" href={noteHref(note.id)}>
                <span>{note.data.title}</span>
                <small>{note.data.isIndex ? 'index note' : note.data.noteRole}</small>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </section>
</Layout>
