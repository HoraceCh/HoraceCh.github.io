---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import {
  loadProjectPublicationModel,
  projectHref,
  type EffectiveProject,
} from '../../utils/projectPublication';

const isPrimaryMaturity = (maturity: string) => !['planned', 'archive'].includes(maturity);
const isPublicStatus = (status: string) => !['planned', 'archived'].includes(status);

const projectModel = await loadProjectPublicationModel();
const listedProjects = projectModel.listed;
const selectedProjects = new Set<EffectiveProject>();
const selectProjects = (predicate: (project: EffectiveProject) => boolean) => {
  const matchingProjects = listedProjects.filter(
    (project) => !selectedProjects.has(project) && predicate(project),
  );
  matchingProjects.forEach((project) => selectedProjects.add(project));
  return matchingProjects;
};

const projectSections = [
  {
    id: 'featured',
    eyebrow: 'Featured',
    title: 'Featured',
    description: 'Inspectable public work with concrete scope and evidence.',
    projects: selectProjects(
      (project) =>
        project.entry.data.visibility === 'public' &&
        project.entry.data.featured &&
        isPrimaryMaturity(project.entry.data.maturity) &&
        isPublicStatus(project.entry.data.status),
    ),
  },
  {
    id: 'ai-workflow',
    eyebrow: 'Systems',
    title: 'AI-assisted Workflow Systems',
    description: 'Public tools and workflows that can be inspected directly.',
    projects: selectProjects(
      (project) =>
        project.entry.data.visibility === 'public' &&
        project.entry.data.portfolioArea === 'ai-workflow' &&
        project.entry.data.maturity !== 'learning-system' &&
        isPrimaryMaturity(project.entry.data.maturity) &&
        isPublicStatus(project.entry.data.status),
    ),
  },
  {
    id: 'learning',
    eyebrow: 'Research',
    title: 'Learning / Research Systems',
    description: 'Structured learning systems and research organization work, not completed engineering claims.',
    projects: selectProjects((project) => project.entry.data.maturity === 'learning-system'),
  },
  {
    id: 'engineering',
    eyebrow: 'Engineering',
    title: 'Engineering / Robotics',
    description: 'Robotics, control, and embodied systems work with public technical evidence.',
    projects: selectProjects(
      (project) =>
        project.entry.data.visibility === 'public' &&
        ['robotics', 'embodied-ai', 'course-project'].includes(project.entry.data.portfolioArea) &&
        project.entry.data.maturity !== 'learning-system' &&
        isPrimaryMaturity(project.entry.data.maturity) &&
        isPublicStatus(project.entry.data.status),
    ),
  },
  {
    id: 'mechanical-design',
    eyebrow: 'Design',
    title: 'Mechanical Design',
    description: 'Mechanical design work with shareable CAD, images, constraints, or engineering documentation.',
    projects: selectProjects(
      (project) =>
        project.entry.data.visibility === 'public' &&
        project.entry.data.portfolioArea === 'mechanical-design' &&
        isPrimaryMaturity(project.entry.data.maturity) &&
        isPublicStatus(project.entry.data.status),
    ),
  },
  {
    id: 'secondary',
    eyebrow: 'Secondary',
    title: 'Secondary / Archive',
    description: 'De-emphasized entries, planned documentation areas, and supporting context.',
    projects: selectProjects(
      (project) =>
        project.entry.data.visibility === 'secondary' || ['planned', 'archive'].includes(project.entry.data.maturity),
    ),
  },
].filter((section) => section.projects.length > 0);
---

<Layout title="Projects" description="A scan-friendly index of projects and engineering work.">
  <section class="article">
    <p class="eyebrow">Projects</p>
    <h1>Project Index</h1>
    <p>
      This page collects selected public projects, ongoing learning systems, and engineering work. Hidden placeholders
      are excluded, and planned or learning-system entries are labeled so they are not read as completed work.
    </p>
  </section>

  {
    projectSections.map((section) => (
      <section class="section" aria-labelledby={`${section.id}-projects`}>
        <SectionHeading
          id={`${section.id}-projects`}
          eyebrow={section.eyebrow}
          title={section.title}
          description={section.description}
        />
        <div class="card-grid" aria-label={section.title}>
          {section.projects.map((project) => (
            <ProjectCard
              title={project.entry.data.title}
              description={project.entry.data.description}
              status={project.entry.data.status}
              category={project.entry.data.category}
              maturity={project.entry.data.maturity}
              tags={project.entry.data.tags}
              href={projectHref(project)}
              links={project.entry.data.links}
            />
          ))}
        </div>
      </section>
    ))
  }
</Layout>
