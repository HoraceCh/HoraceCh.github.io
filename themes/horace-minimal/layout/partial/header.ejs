<header class="site-header">
  <a class="brand" href="<%- url_for('/') %>" aria-label="Home">
    <span class="brand-mark">H</span>
    <span class="brand-text"><%= config.title %></span>
  </a>
  <button class="nav-toggle" type="button" aria-label="Toggle navigation">Menu</button>
  <nav class="site-nav" aria-label="Main navigation">
    <% Object.keys(config.menu || {}).forEach(function(name) { %>
      <a href="<%- url_for(config.menu[name]) %>"><%= name %></a>
    <% }) %>
  </nav>
</header>
